rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Journal images: each user can only read/write their own folder
    match /journal/{uid}/{imageId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Feedback screenshots: any authenticated user can upload; admins read via console
    match /feedback/{submissionId}/{fileName} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read:  if request.auth != null;
    }

    // Community post images: authenticated users can upload to their own folder;
    // anyone (including unauthenticated) can read.
    match /community-posts/{uid}/{uploadTs}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
