rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Per-user data ──────────────────────────────────────────────────────────
    // All sessions, gear, journal, profile, bulletinState, etc. live here.
    // Only the owner may read or write their own document, with one exception:
    // activePostCount is maintained exclusively by Cloud Functions (Admin SDK)
    // and must never be writable from the client — otherwise the 3-post cap
    // enforced in the Firestore rules below could be bypassed.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Users may create their own profile, but may not initialise activePostCount.
      allow create: if request.auth != null && request.auth.uid == uid
                    && !('activePostCount' in request.resource.data);

      // Users may update any profile field except activePostCount.
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data)
                          .affectedKeys().hasAny(['activePostCount']);

      // Users may delete their own profile (account-deletion flow).
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Community posts ────────────────────────────────────────────────────────
    match /communityPosts/{postId} {
      // Authenticated users may read community posts
      allow read: if request.auth != null;

      // Creates go through the validateAndCreateCommunityPost Cloud Function
      // (Admin SDK, bypasses rules). This rule is a defence-in-depth gate that
      // blocks any direct client write when the user already has 3 active posts.
      // activePostCount is incremented by the CF on create and decremented on
      // expiry/removal — and is write-protected on users/{uid} above, so it
      // cannot be zeroed out to bypass this check.
      allow create: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid))
                          .data.get('activePostCount', 0) < 3;

      // Owners may only update their own post to set status = 'removed'.
      // All other fields are locked to prevent tampering.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.status    == 'removed'
                    && request.resource.data.userId    == resource.data.userId
                    && request.resource.data.imageUrls == resource.data.imageUrls
                    && request.resource.data.caption   == resource.data.caption;

      // Hard deletes from the client are never allowed
      allow delete: if false;

      // ── Rating subcollection ─────────────────────────────────────────────
      // Writes go through the ratePost Cloud Function (Admin SDK, bypasses rules).
      // Authenticated users may read any rating doc (needed to fetch their own rating).
      match /ratings/{userId} {
        allow read: if request.auth != null;
        allow write: if false; // Cloud Function only
      }
    }

    // ── Gemini request queue ───────────────────────────────────────────────────
    // Jobs are written only by Cloud Functions (Admin SDK bypasses rules).
    // Each user may read their own job document to poll for results.
    match /geminiQueue/{jobId} {
      allow read:  if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ── Feedback submissions ───────────────────────────────────────────────────
    // Authenticated users may submit feedback; no client-side reads allowed.
    // Feedback is read-only via Firebase Console / Admin SDK.
    match /feedback/{docId} {
      allow read: if false;
      allow create: if request.auth != null;
    }

  }
}
